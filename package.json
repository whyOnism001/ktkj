{
  "name": "kaitou-quoter",
  "version": "2.0.0",
  "description": "开投智云 AI 报价助手",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:electron": "npm run build && tsc -p tsconfig.electron.json",
    "start": "node dist/server/index.js",
    "electron:dev": "NODE_ENV=development electron electron/main.js",
    "electron:build": "npm run build:electron && electron-builder",
    "electron": "electron electron/main.js"
  },
  "build": {
    "appId": "com.kaitou.quoter",
    "productName": "开投智云AI报价助手",
    "directories": { "output": "release" },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "config.json",
      "!node_modules"
    ],
    "extraResources": [
      { "from": "data/", "to": "data/" }
    ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "fuse.js": "^7.0.0",
    "openai": "^4.47.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vite": "^5.0.0"
  }
}
